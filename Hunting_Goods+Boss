        repeat
            task.wait(Time)
            if not IsOn then
                break
            end                    
            local Pet = Pet_Model.PrimaryPart
            if Pet then
                Char:FindFirstChild("HumanoidRootPart").Position = Pet.Position + Vector3.new(0, 5, 0)
